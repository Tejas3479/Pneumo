# PneumoDex AI — Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── Redis ─────────────────────────────────────────────────────────────────────
# URL for the Celery message broker. Use "redis://localhost:6379/0" for local dev.
# Use "redis://redis:6379/0" inside Docker Compose.
REDIS_URL=redis://localhost:6379/0

# ── Model ─────────────────────────────────────────────────────────────────────
# Model architecture to use for inference: vit | resnet | medfound
MODEL_TYPE=vit

# ── Security ──────────────────────────────────────────────────────────────────
# HMAC secret key for audit ledger row-chain integrity verification.
# Change this to a long random string in production!
LEDGER_SECRET_KEY=change-me-to-a-long-random-string

# Optional: API key to protect all inference endpoints (leave blank to disable)
PNEUMO_API_KEY=

# ── Active Learning ───────────────────────────────────────────────────────────
# Number of clinician-corrected samples required to trigger automatic retraining
AL_RETRAIN_THRESHOLD=50

# Number of fine-tuning epochs per Active Learning retraining cycle
AL_RETRAIN_EPOCHS=3

# ── Drift Monitoring ──────────────────────────────────────────────────────────
# Webhook URL to receive POST alert when PSI drift score exceeds 0.25
# Leave blank to disable webhooks
DRIFT_WEBHOOK_URL=

# ── Circuit Breaker ───────────────────────────────────────────────────────────
# Number of consecutive inference failures before circuit opens (degraded mode)
CB_FAIL_MAX=5

# Seconds before circuit breaker attempts to close (re-enable model)
CB_RESET_TIMEOUT=30

# ── MLflow ────────────────────────────────────────────────────────────────────
# Tracking URI for MLflow experiment logger (local or remote)
MLFLOW_TRACKING_URI=http://localhost:5000
